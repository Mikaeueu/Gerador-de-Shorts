# Copie este arquivo para `.env` e preencha conforme for implementando as etapas.
# IMPORTANTE: nunca commite o arquivo .env (já está no .gitignore).

# ============================================================
# Etapa 3 — LLM análise viral (Google Gemini)
# ============================================================
# Como pegar (gratuito, sem cartão):
#   1. Acesse https://aistudio.google.com/app/apikey
#   2. Faça login com sua conta Google
#   3. Clique em "Create API key" → "Create API key in new project"
#   4. Copie a chave (começa com AIza...) e cole abaixo
#
# Free tier: 1500 requisições/dia, 15/min — suficiente pra uso pessoal intenso.
GOOGLE_API_KEY=

# Modelo Gemini a usar (default: gemini-2.5-flash)
# Opções: gemini-2.5-flash (rápido, gratuito) | gemini-2.5-pro (mais preciso, mais lento)
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# Groq (Llama 3.3 70B) — RECOMENDADO
# ============================================================
# Usado pelo REFINER (Etapa 2.5) como provider PRIMÁRIO.
# Por quê: free tier sem limite diário fixo, super rápido.
# Reserva a quota do Gemini pra Etapa 3 (analyzer) que é mais crítica.
#
# Como pegar (gratuito, sem cartão):
#   1. Acesse https://console.groq.com/keys
#   2. Login com Google/GitHub
#   3. Clique em "Create API Key"
#   4. Cole abaixo (começa com gsk_...)
GROQ_API_KEY=

# Modelo Groq (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================
# OpenAI (GPT-4o-mini) — fallback opcional
# ============================================================
# Usado APENAS se Groq E Gemini falharem na cadeia de fallback.
# Precisa cartão de crédito (free tier inicial limitado).
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Ollama local — fallback offline (ilimitado)
# ============================================================
# Usado como último recurso na chain. Roda 100% local, sem quota.
# Instale: https://ollama.com/  +  ollama pull llama3.2:3b
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b
